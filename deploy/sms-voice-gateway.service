[Unit]
Description=SMS Voice Gateway
After=network.target
Wants=network.target

[Service]
Type=simple
User=__SERVICE_USER__
Group=__SERVICE_GROUP__
WorkingDirectory=__WORKING_DIRECTORY__
Environment=PYTHONUNBUFFERED=1
Environment=SMS_GATEWAY_SYSTEMD_SERVICE=sms-voice-gateway.service
EnvironmentFile=-__ENV_FILE__
ExecStart=__PYTHON_BIN__ -m uvicorn app.main:app --host __HOST__ --port __PORT__
Restart=always
RestartSec=5
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
