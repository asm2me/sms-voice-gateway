# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Shared secret for webhook validation and admin endpoints
WEBHOOK_SECRET=change_me_in_production

# ── TTS Provider ──────────────────────────────────────────────────────────────
# Options: google | aws_polly | openai | elevenlabs
TTS_PROVIDER=google

TTS_LANGUAGE=en-US
TTS_VOICE=en-US-Neural2-F
TTS_SPEAKING_RATE=0.90

# How many times to repeat the OTP in the call (baked into WAV at synthesis time)
PLAYBACK_REPEATS=3
# Milliseconds of silence between repeats
PLAYBACK_PAUSE_MS=1500

# Audio cache TTL (seconds) – 7 days default
AUDIO_CACHE_TTL=604800

# ── Google Cloud TTS ──────────────────────────────────────────────────────────
# Path to your Google service-account JSON key file
GOOGLE_CREDENTIALS_JSON=/etc/sms-gateway/google-sa.json

# ── AWS Polly ─────────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_POLLY_VOICE_ID=Joanna
# AWS_POLLY_ENGINE=neural

# ── OpenAI TTS ────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_TTS_MODEL=tts-1-hd
# OPENAI_TTS_VOICE=nova

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=sms_gw:

# ── Audio file paths ─────────────────────────────────────────────────────────
# Local directory to store synthesised WAV files
AUDIO_CACHE_DIR=./audio_cache

# Asterisk sounds directory where WAV files will be symlinked.
# Asterisk will reference files as "sms_otp/<hash>" (no .wav extension).
# Must be readable by the asterisk user.
ASTERISK_SOUNDS_DIR=/var/lib/asterisk/sounds/sms_otp

# ── Asterisk AMI ──────────────────────────────────────────────────────────────
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=sms_gateway
AMI_SECRET=your_ami_secret_here

# SIP channel prefix for outbound calls.
# Examples:
#   PJSIP/my_trunk        → PJSIP trunk named "my_trunk"
#   SIP/my_trunk          → chan_sip trunk
#   DAHDI/g1              → DAHDI group 1
SIP_CHANNEL_PREFIX=PJSIP/trunk_outbound

# CallerID shown to the called party
OUTBOUND_CALLER_ID=OTP Service <0000>

# Seconds to ring before giving up
CALL_ANSWER_TIMEOUT=30

# Asterisk dialplan context (must match sms_voice_otp.conf)
ASTERISK_CONTEXT=sms-voice-otp
ASTERISK_EXTEN=s
ASTERISK_PRIORITY=1

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_HOURLY=3
RATE_LIMIT_DAILY=10
