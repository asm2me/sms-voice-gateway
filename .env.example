# ── Bootstrap ────────────────────────────────────────────────────────────────
# Minimal values needed to start the app and reach the admin UI.
HOST=0.0.0.0
PORT=8000
DEBUG=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
DELIVERY_REPORT_STORE_PATH=

# ── First-run note ────────────────────────────────────────────────────────────
# Configure TTS, AMI, SMPP, SIP, rate limits, playback, cache paths, and
# provider credentials in the web admin UI. Those settings are persisted to
# the config store and should not normally live in .env.